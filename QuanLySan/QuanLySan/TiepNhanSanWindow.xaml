<Window x:Class="QuanLySan.TiepNhanSanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tiếp nhận sân"
        Width="750" Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <!-- ===== COLOR PALETTE ===== -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1B2A4A"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#222222"/>
        <SolidColorBrush x:Key="InputBorder" Color="#CCCCCC"/>

        <!-- ===== SIMPLE TEXTBOX STYLE ===== -->
        <Style x:Key="SimpleTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ===== SIMPLE COMBOBOX STYLE ===== -->
        <Style x:Key="SimpleComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ===== LABEL STYLE ===== -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ===== SIMPLE BUTTON STYLE ===== -->
        <Style x:Key="SimpleButton" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="Background" Value="#F0F0F0"/>
        </Style>

        <!-- ===== DATAGRID STYLE ===== -->
        <Style x:Key="StyledDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#2A3E6A"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <Border Background="White" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER BAR ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource PrimaryBrush}"
                    Padding="20,12">
                <Grid>
                    <TextBlock Text="Tiếp nhận sân"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="16" FontWeight="Bold"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnClose_Click"
                            Width="28" Height="28"/>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20,14,20,16">
                <StackPanel>

                    <!-- ── ROW 1: Tên sân | Loại sân | Địa chỉ ── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Tên sân -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tên sân" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtTenSan" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>

                        <!-- Loại sân -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Loại sân" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cboLoaiSan" Style="{StaticResource SimpleComboBox}"
                                      DisplayMemberPath="TenLoaiSan"/>
                        </StackPanel>

                        <!-- Địa chỉ -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Địa chỉ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtDiaChi" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── ROW 2: Ghi chú | Tình trạng ── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Ghi chú -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ghi chú" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtGhiChu" Style="{StaticResource SimpleTextBox}"/>
                        </StackPanel>

                        <!-- Tình trạng -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Tình trạng" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cboTinhTrang" Style="{StaticResource SimpleComboBox}"
                                      DisplayMemberPath="TenTinhTrang"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── SEPARATOR ── -->
                    <Border Height="1" Background="#D0D0D0" Margin="0,4,0,12"/>

                    <!-- ── SECTION: Bảng giá theo loại ngày ── -->
                    <TextBlock Text="Bảng giá theo loại ngày"
                               FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,10"/>

                    <!-- ── ROW 3: Giờ bắt đầu | Giờ kết thúc | Loại ngày | Đơn giá ── -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Giờ bắt đầu -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Giờ bắt đầu" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtGioBatDau"
                                     Style="{StaticResource SimpleTextBox}"
                                     Text="07:00"/>
                        </StackPanel>

                        <!-- Giờ kết thúc -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Giờ kết thúc" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtGioKetThuc"
                                     Style="{StaticResource SimpleTextBox}"
                                     Text="22:00"/>
                        </StackPanel>

                        <!-- Loại ngày -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Loại ngày" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="cboLoaiNgay" Style="{StaticResource SimpleComboBox}"
                                      DisplayMemberPath="TenLoaiNgay"/>
                        </StackPanel>

                        <!-- Đơn giá -->
                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Đơn giá" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="txtDonGia" Style="{StaticResource SimpleTextBox}" IsEnabled="False"/>
                        </StackPanel>
                    </Grid>

                    <!-- ── BUTTON: Tìm sân, Lưu ── -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                        <Button Content="Tìm sân"
                        Style="{StaticResource SimpleButton}"
                                Margin="8,0,0,0"
                                Click="BtnXoaDongGia_Click"/>
                        <Button Content="Lưu"
                                Style="{StaticResource SimpleButton}"
                                Margin="8,0,0,0"
                                Click="BtnXoaDongGia_Click"/>
                    </StackPanel>

                    <!-- ── DATAGRID: Danh sách giá ── -->
                    <DataGrid x:Name="dgBangGia"
                              Style="{StaticResource StyledDataGrid}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                              Height="160"
                              Margin="0,0,0,16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="50"/>
                            <DataGridTextColumn Header="Giờ bắt đầu" Binding="{Binding GioBatDau}" Width="*"/>
                            <DataGridTextColumn Header="Giờ kết thúc" Binding="{Binding GioKetThuc}" Width="*"/>
                            <DataGridTextColumn Header="Loại ngày" Binding="{Binding LoaiNgay}" Width="*"/>
                            <DataGridTextColumn Header="Đơn giá" Binding="{Binding DonGia, StringFormat=N0}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ── SEPARATOR ── -->
                    <Border Height="1" Background="#D0D0D0" Margin="0,0,0,14"/>

                    <!-- ── FOOTER BUTTONS ── -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="✕ Xóa dòng"
                                Style="{StaticResource SimpleButton}"
                                Click="BtnLuu_Click"/>
                        <Button Content="Làm mới"
                                Style="{StaticResource SimpleButton}"
                                Margin="8,0,0,0"
                                Click="BtnLamMoi_Click"/>
                        <Button Content="Đóng"
                                Style="{StaticResource SimpleButton}"
                                Margin="8,0,0,0"
                                Click="BtnClose_Click"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
